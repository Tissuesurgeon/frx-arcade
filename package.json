{
  "name": "frx-arcade",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build --workspace=@frx/shared && turbo run dev --filter=@frx/web --filter=@frx/backend",
    "dev:web": "turbo run dev --filter=@frx/web",
    "dev:backend": "turbo run dev --filter=@frx/backend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:migrate": "npm run db:migrate --workspace=@frx/backend",
    "db:generate": "npm run db:generate --workspace=@frx/backend",
    "db:push": "npm run db:push --workspace=@frx/backend",
    "db:seed": "npm run db:seed --workspace=@frx/backend"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}
