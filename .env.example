# FRX Arcade — environment variables
# Copy to `.env` at repo root: cp .env.example .env
# Both apps/backend and apps/web load from the root `.env` via dotenv-cli.

# ── Shared ──────────────────────────────────────────────

# Node runtime mode. Use `development` locally; set `production` for deployed builds.
NODE_ENV=development

# ── apps/web (Next.js) ──────────────────────────────────
# NEXT_PUBLIC_* vars are exposed to the browser — never put secrets here.

# Base URL of the Express API. Used for REST calls (auth, credits, tournaments, scores).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Socket.IO server URL for realtime leaderboard / tournament updates.
NEXT_PUBLIC_WS_URL=http://localhost:4000

# X Layer chain ID shown in UI/docs. Wagmi chain config uses packages/shared (1952 testnet).
NEXT_PUBLIC_CHAIN_ID=1952

# Deployed SwapCreditRouter on X Layer testnet.
# Required for OKB → FRX credit swaps in the browser (DepositModal calls swapForCredits).
NEXT_PUBLIC_SWAP_CREDIT_ROUTER_ADDRESS=

# Deployed FRXArcadeHook (Uniswap V4 BaseHook) address. Shown on landing + explorer links.
NEXT_PUBLIC_FRX_ARCADE_HOOK_ADDRESS=

# Uniswap V4 PoolManager on X Layer testnet (official or self-deployed).
NEXT_PUBLIC_POOL_MANAGER_ADDRESS=

# Legacy alias — optional fallback if NEXT_PUBLIC_SWAP_CREDIT_ROUTER_ADDRESS is unset.
NEXT_PUBLIC_DEPOSIT_ROUTER_ADDRESS=

# Deployed TreasuryVault address. Optional display/verification.
NEXT_PUBLIC_TREASURY_VAULT_ADDRESS=

# Deployed CreditManager address. Reserved for future on-chain reads.
NEXT_PUBLIC_CREDIT_MANAGER_ADDRESS=

# ── apps/backend (Express + Prisma) ─────────────────────

# HTTP port for the API and Socket.IO server.
PORT=4000

# PostgreSQL connection string for Prisma. Default Docker Compose maps Postgres to host port 5433.
DATABASE_URL=postgresql://frx:frx_dev@localhost:5433/frx_arcade?schema=public

# Redis URL for rate limiting and session-adjacent caching. Leave as-is if using docker compose redis.
REDIS_URL=redis://localhost:6379

# Secret used to sign JWT session tokens after wallet SIWE login. Use a long random string in production.
JWT_SECRET=change-me-in-production-use-long-random-string

# Allowed browser origins for CORS and Socket.IO (comma-separated in dev).
# Development also allows localhost / LAN IPs (e.g. http://192.168.x.x:3000).
CORS_ORIGIN=http://localhost:3000

# OpenAI API key for the tournament AI agent (flagged-score summaries). Leave empty to skip AI calls.
OPENAI_API_KEY=

# Comma-separated wallet addresses granted ADMIN role on sign-in (dashboard access, admin routes).
ADMIN_WALLETS=0x0000000000000000000000000000000000000001

# SwapCreditRouter address (same as NEXT_PUBLIC_SWAP_CREDIT_ROUTER_ADDRESS).
# Backend verifies V4 swap txs: PoolManager Swap + hook SwapRouted + router CreditsPurchased.
SWAP_CREDIT_ROUTER_ADDRESS=

# FRXArcadeHook address on X Layer testnet.
FRX_ARCADE_HOOK_ADDRESS=

# Uniswap V4 PoolManager address on X Layer testnet.
POOL_MANAGER_ADDRESS=

# bytes32 pool id from deploy logs (PoolId.unwrap(poolKey.toId())).
POOL_ID=

# ArcadeQuoteToken — V4 pool counter-asset (not gameplay credits).
ARCADE_QUOTE_TOKEN_ADDRESS=

# Block number when hook was deployed — hook indexer starts scanning from here.
HOOK_DEPLOY_BLOCK=

# TreasuryVault address on X Layer testnet.
TREASURY_VAULT_ADDRESS=

# Legacy alias — optional fallback for SWAP_CREDIT_ROUTER_ADDRESS.
DEPOSIT_ROUTER_ADDRESS=

# ── packages/contracts (Foundry deploy) ─────────────────

# Deployer wallet private key (hex, with or without 0x prefix). Used by `forge script`
# and by the backend to sync OKB/USD prices and send FRX→OKB redemption payouts.
# Never commit a real key — testnet-only.
PRIVATE_KEY=

# JSON-RPC endpoint for X Layer testnet. Backend verification and indexer use this URL.
XLAYER_RPC_URL=https://testrpc.xlayer.tech/terigon

# Chain ID for X Layer testnet (1952). Must match the network where contracts are deployed.
XLAYER_CHAIN_ID=1952

# Pricing: 1 USD of OKB = 25 FRX credits. Backend syncs live OKB/USD to SwapCreditRouter every 60s.
